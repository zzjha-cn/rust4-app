{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Blink Reminder",
  "version": "0.1.0",
  "identifier": "com.blink-reminder.app",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "visible": false,
        "width": 1,
        "height": 1,
        "decorations": false,
        "skipTaskbar": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
